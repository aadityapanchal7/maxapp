{
  "expo": {
    "name": "Max",
    "slug": "cannon-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D0D0D"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.cannon.mobile",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Max uses your photo library to attach images in community channels, chat, and profile or progress photos.",
        "NSPhotoLibraryAddUsageDescription": "Max saves your face scan from results to your photo library when you choose Save to photos."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0D0D0D"
      },
      "package": "com.cannon.mobile",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Max to access your camera for face scans.",
          "microphonePermission": "Allow Max to access your microphone for face scan video recording."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow Max to access photos to save your scan from results.",
          "savePhotosPermission": "Allow Max to save your face scan to your photo library.",
          "isAccessMediaLocationEnabled": false
        }
      ],
      "expo-video",
      "expo-audio",
      "expo-font"
    ],
    "scheme": "cannon",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "extra": {
      "eas": {
        "projectId": "e88cbff0-beda-47c1-a763-5a81698030bd"
      },
      "supportEmail": "support@example.com",
      "privacyPolicyUrl": "",
      "termsOfServiceUrl": "",
      "communityGuidelinesUrl": "",
      "cookieNoticeUrl": "",
      "sendblueSmsNumber": "+16468304204",
      "sendblueDisplayNumber": "+1 (646) 830-4204"
    }
  }
}
