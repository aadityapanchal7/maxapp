# Example public env vars for EAS / local builds (not gitignored — copy values into EAS Secrets or export before build).
# app.config.js reads these at build time.
#
# Static legal pages live in the repo at /legal (privacy.html, terms.html, etc.). Host that folder on any HTTPS
# static host, then set URLs below to match (example paths).

EXPO_PUBLIC_SUPPORT_EMAIL=you@yourdomain.com
EXPO_PUBLIC_PRIVACY_POLICY_URL=https://yourdomain.com/legal/privacy.html
EXPO_PUBLIC_TERMS_URL=https://yourdomain.com/legal/terms.html
EXPO_PUBLIC_COMMUNITY_GUIDELINES_URL=https://yourdomain.com/legal/community-guidelines.html
EXPO_PUBLIC_COOKIE_NOTICE_URL=https://yourdomain.com/legal/cookies.html
